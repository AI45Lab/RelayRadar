{
  "name": "relayradar",
  "private": true,
  "version": "0.1.0",
  "license": "BUSL-1.1",
  "description": "RelayRadar: OpenAI-compatible API observability and protection platform",
  "packageManager": "pnpm@10.29.2",
  "scripts": {
